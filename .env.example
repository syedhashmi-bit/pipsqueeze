# ─────────────────────────────────────────────────────────────────────────────
# PipSqueeze — Environment Configuration
# Copy this file to .env and fill in every value marked REQUIRED.
# Lines starting with # are comments and are ignored.
# ─────────────────────────────────────────────────────────────────────────────


# ── App ──────────────────────────────────────────────────────────────────────

# REQUIRED — Flask session encryption key. Must be long and random.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# REQUIRED — Admin login credentials (username + password for the web UI)
APP_USERNAME=admin
APP_PASSWORD=

# REQUIRED — Base32 TOTP secret for two-factor authentication (2FA).
# Generate one with: python3 -c "import pyotp; print(pyotp.random_base32())"
# Then scan the provisioning URI into Google Authenticator, Authy, or 1Password.
TOTP_SECRET=


# ── WireGuard Server ─────────────────────────────────────────────────────────
# These values are written into every client .conf file that PipSqueeze generates.

# REQUIRED — WireGuard public key of the interface on your MikroTik router.
# Find it in: Winbox → WireGuard → your interface → Public Key
SERVER_PUBLIC_KEY=

# REQUIRED — Your VPS public IP address, or the domain pointing to it.
# This becomes the [Peer] Endpoint in client config files.
# Example: 203.0.113.42  or  vpn.yourdomain.com
SERVER_IP=

# REQUIRED — WireGuard listen port configured on your MikroTik interface.
# Default is 51820. Make sure this port is open in your firewall.
SERVER_PORT=51820

# REQUIRED — DNS server written into client config files.
# Use your router IP for split-DNS, or a public resolver like 1.1.1.1
# Example: 192.168.88.1  or  1.1.1.1  or  8.8.8.8
CLIENT_DNS=1.1.1.1


# ── MikroTik RouterOS API ─────────────────────────────────────────────────────

# REQUIRED — IP address of your MikroTik router (reachable from the VPS).
# Example: 192.168.88.1
MT_HOST=

# REQUIRED — MikroTik API username.
# Create a dedicated user in Winbox → System → Users with policy: read + write + api
MT_USERNAME=api

# REQUIRED — MikroTik API user password.
MT_PASSWORD=

# OPTIONAL — MikroTik API port. Default 8728 (plaintext). Use 8729 for TLS.
# Check Winbox → IP → Services → api
MT_PORT=8728

# REQUIRED — Exact name of the WireGuard interface on MikroTik.
# Find it in: Winbox → WireGuard → Interface Name column.
# Example: WireGuard1
MT_WIREGUARD_INTERFACE=WireGuard1

# OPTIONAL — WireGuard gateway pin on the map (/map page).
# Set these to the physical location of your MikroTik router (the WireGuard gateway),
# NOT the VPS location. This pin is shown in cyan on the map.
# Example: home router in Hobart, Tasmania
MT_LOCATION_NAME=Hobart, Tasmania, Australia
MT_LAT=-42.8821
MT_LON=147.3272


# ── Security ──────────────────────────────────────────────────────────────────

# OPTIONAL — Number of failed login attempts before an IP is locked out.
MAX_LOGIN_ATTEMPTS=5

# OPTIONAL — How many minutes a locked-out IP stays locked.
LOCKOUT_MINUTES=15

# OPTIONAL — Minutes of inactivity before the admin session expires.
SESSION_TIMEOUT_MIN=30

# OPTIONAL — IP whitelist. Only these IPs can access the dashboard.
# Comma-separated. Leave blank to allow connections from any IP.
# Example: 203.0.113.10,203.0.113.20
IP_WHITELIST=


# ── Notifications ─────────────────────────────────────────────────────────────
# Notification channel credentials are stored in the database (via the UI).
# Only the weekly digest schedule is configured here.

# OPTIONAL — Day of week to automatically send the weekly digest email.
# Accepted values: monday, tuesday, wednesday, thursday, friday, saturday, sunday
WEEKLY_DIGEST_DAY=monday
